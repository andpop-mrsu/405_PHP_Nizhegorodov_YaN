#!/usr/bin/env php
<?php

$autoloadPaths = [
    __DIR__ . '/../../../autoload.php', // глобально
    __DIR__ . '/../vendor/autoload.php' // локально
];

foreach ($autoloadPaths as $path) {
    if (file_exists($path)) {
        require_once $path;
        break;
    }
}

use function Radiculitca\Calculator\Controller\startGame;

startGame();